# Server-side key (used by api-server when started nearby)
GC_API_KEY=gc_live_2de48fed92cbaa520e7987d9b726d3dd
GC_BASE_URL=http://localhost:3000/api

# Vite-exposed variables for the browser client. These mirror the
# server-side values so the demo client can call the GuildCraft SDK
# directly when needed. Keep these in sync with the GC_* values above.
VITE_GC_API_KEY=gc_live_2de48fed92cbaa520e7987d9b726d3dd
VITE_GC_BASE_URL=http://localhost:3000/api

# Dedicated world-event persistence API (separate from core game API proxy)
VITE_WORLD_EVENTS_BASE_URL=http://localhost:3002
# Local dev server port and base path
PORT=5173
BASE_PATH=/
# NPC character IDs are no longer required. The game uses canonical node names
# (e.g. "Forge_9", "The_Weaver", "Aegis_Prime") when calling the SDK.
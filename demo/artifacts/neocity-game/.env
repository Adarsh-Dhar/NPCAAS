# Server-side key (used by api-server when started nearby)
GC_API_KEY=gc_live_a605c99c662160d5b1a67646bc4281d7
GC_BASE_URL=http://localhost:3000/api

# Vite-exposed variables for the browser client. These mirror the
# server-side values so the demo client can call the GuildCraft SDK
# directly when needed. Keep these in sync with the GC_* values above.
VITE_GC_API_KEY=gc_live_a605c99c662160d5b1a67646bc4281d7
VITE_GC_BASE_URL=/api
# Local proxy target for /api during Vite dev. Point this to whichever
# backend hosts the GuildCraft-compatible routes.
GC_PROXY_TARGET=http://localhost:3000
# Local dev server port and base path
PORT=5173
BASE_PATH=/
# NPC character IDs are no longer required. The game now uses semantic names
# (e.g. "SILAS_VANCE", "ARCHIVE_NODE_819", "SCRAP_ENFORCER") directly when calling the SDK.
# If you previously added character UUIDs here, they can be removed.
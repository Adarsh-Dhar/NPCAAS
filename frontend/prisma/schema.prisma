// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id         String      @id @default(cuid())
  name       String
  apiKey     String      @unique
  globalContext String?  @db.Text
  createdAt  DateTime    @default(now())
  characters Character[]
}

model Character {
  id                 String        @id @default(cuid())
  name               String
  walletAddress      String
  aaChainId          Int           @default(42161)
  aaProvider         String        @default("kite-aa")
  smartAccountId     String?
  smartAccountStatus String        @default("created")
  isDeployedOnChain  Boolean       @default(true)
  deploymentTxHash   String?
  computeUsageTokens BigInt        @default(0)
  computeLimitTokens BigInt        @default(5000)
  lastComputeResetAt DateTime      @default(now())
  teeAttestationProof String?
  config             Json
  adaptation         Json?
  projects           Project[]
  logs               NpcLog[]
  actions            ActionQueue[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model NpcLog {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  eventType   String    // "CHAT", "TRADE", "BROADCAST", "LOOP", "TRIGGER"
  details     Json
  createdAt   DateTime  @default(now())

  @@index([characterId])
  @@index([characterId, eventType])
}

model ActionQueue {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  actionType  String    // "CHECK_MARKET", "BUY_MATERIALS", "TRANSFER", "CHAT"
  payload     Json?
  status      String    @default("PENDING") // PENDING, EXECUTED, FAILED
  executeAt   DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([characterId])
  @@index([characterId, status])
}

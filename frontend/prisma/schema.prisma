// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"

}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String     @id @default(cuid())
  name      String
  apiKey    String     @unique
  createdAt DateTime   @default(now())
  characters Character[]
}

model Character {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  walletAddress String
  aaChainId     Int @default(42161)
  aaProvider    String @default("kite-aa")
  smartAccountId String?
  smartAccountStatus String @default("created")
  isDeployedOnChain Boolean @default(true)
  deploymentTxHash String?
  config    Json     // Stores the 5-layer configuration (Economic, Cognitive, Social, Agentic, Infrastructure)
  adaptation Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

DATABASE_URL="postgresql://admin:kitedegen@localhost:5432/guildcraft?schema=public"
GITHUB_TOKEN="your_github_token_here"
# Optional LLM tuning
# LLM_TIMEOUT_MS=45000
# LLM_MAX_RETRIES=2
KITE_TREASURY_PRIVATE_KEY=""
KITE_TREASURY_MIN_PROVISION="0"
KITE_MARKET_RATE_API_URL="https://api.binance.com/api/v3/ticker/price"
ALLOWED_TRADE_TOKENS="PYUSD,SOL,USDC,BTC"
NEXT_PUBLIC_TEE_RECHARGE_ADDRESS="0xFe5e03799Fe833D93e950d22406F9aD901Ff3Bb9"

# Passport configuration (optional)
# On-chain registry / proxy contract address responsible for configuring agent sessions
KITE_PASSPORT_REGISTRY_ADDRESS=""
# Token decimals for the budget currency (e.g., PYUSD often uses 6 decimals)
KITE_PASSPORT_TOKEN_DECIMALS="6"
# Default passport budget (human-readable units, will be parsed with decimals above)
DEFAULT_PASSPORT_BUDGET="100"
# Default passport session duration in seconds (defaults to 86400 = 1 day)
DEFAULT_PASSPORT_DURATION_SECONDS="86400"
